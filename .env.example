# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + anon key are safe for the client bundle (NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key: SERVER-SIDE ONLY. Never expose with NEXT_PUBLIC_,
# never commit a real value. (security.md §Supabase-specific rules)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI providers (all calls server-side only) ───────────────────────────────
# Claude API: classification, billing summaries, weekly reports, boss chatbot
ANTHROPIC_API_KEY=
# Low-cost model for Goal Sheet description refinement (C-5)
MINIMAX_API_KEY=

# ── Inngest (background jobs, WF-001..WF-009) ───────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── FM sync (WF-009) — n8n webhook endpoint ─────────────────────────────────
FM_SYNC_WEBHOOK_URL=

# ── Cayan payments (Phase 2 — leave empty until P2-07) ──────────────────────
CAYAN_MERCHANT_NAME=
CAYAN_MERCHANT_SITE_ID=
CAYAN_MERCHANT_KEY=
CAYAN_WEBHOOK_SECRET=
